{
  "name": "autoscreeps-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI for running local autoscreeps experiments",
  "bin": {
    "autoscreeps": "dist/cli.js"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "mongodb": "^7.1.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
