{
  "name": "autoscreeps-basic-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Very basic Screeps bot built with Vite and Vitest",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "vite build",
    "benchmark:dijkstra": "node --expose-gc scripts/benchmark-dijkstra.ts",
    "benchmark:distance-transform": "node --expose-gc scripts/benchmark-distance-transform.ts",
    "benchmark:stamp-placement": "node --expose-gc scripts/benchmark-stamp-placement.ts",
    "benchmark:road-planning": "node --expose-gc scripts/benchmark-road-planning.ts",
    "benchmark:flood-fill": "node --expose-gc scripts/benchmark-flood-fill.ts",
    "generate:road-planning-fixtures": "node scripts/generate-road-planning-fixtures.ts",
    "watch": "vite build --watch",
    "push:pserver": "vite build --mode pserver",
    "preview:dijkstra": "node scripts/generate-dijkstra-preview.ts",
    "preview:distance-transform": "node scripts/generate-distance-transform-preview.ts",
    "preview:stamp-placement": "node scripts/generate-stamp-placement-preview.ts",
    "preview:road-planning": "node scripts/generate-road-planning-preview.ts",
    "preview:flood-fill": "node scripts/generate-flood-fill-preview.ts",
    "watch:pserver": "vite build --watch --mode pserver",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/screeps": "^3.3.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
